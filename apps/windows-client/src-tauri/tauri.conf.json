{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Audio",
  "version": "0.1.0",
  "identifier": "com.ai-audio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Audio",
        "width": 1180,
        "height": 780,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "AI Audio",
    "copyright": "Copyright (c) 2026"
  }
}

