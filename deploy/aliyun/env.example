API_ENV=production
API_VERSION=0.2.0
API_DOMAIN=api.example.com

HMAC_SECRET=replace-with-64-plus-random-chars
JWT_SECRET=replace-with-64-plus-random-chars
JWT_ACCESS_TTL_SECONDS=7200
JWT_REFRESH_TTL_SECONDS=2592000

MYSQL_HOST=rm-xxxx.mysql.rds.aliyuncs.com
MYSQL_PORT=3306
MYSQL_DATABASE=ai_audio
MYSQL_USER=ai_audio_api
MYSQL_PASSWORD=replace-with-rds-password

REDIS_HOST=172.17.0.1
REDIS_PORT=6379
REDIS_PASSWORD=replace-with-redis-password
REDIS_DB=0

SMS_DRY_RUN=false
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_REGION_ID=cn-hangzhou
